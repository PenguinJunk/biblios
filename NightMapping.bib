@Article{SchulteRomerMSD2019,
  author           = {Schulte-R\"{o}mer, Nona and Meier, Josiane and S\"{o}ding, Max and Dannemann, Etta},
  date             = {2019},
  journaltitle     = {Sustainability},
  title            = {The {LED} Paradox: How Light Pollution Challenges Experts to Reconsider Sustainable Lighting},
  doi              = {10.3390/su11216160},
  issn             = {2071-1050},
  number           = {21},
  url              = {https://www.mdpi.com/2071-1050/11/21/6160},
  volume           = {11},
  abstract         = {In the 21st century, the notion of “sustainable lighting” is closely associated with LED technology. In the past ten years, municipalities and private light users worldwide have installed light-emitting diodes in urban spaces and public streets to save energy. Yet an increasing body of interdisciplinary research suggests that supposedly sustainable LED installations are in fact unsustainable, because they increase light pollution. Paradoxically, blue-rich cool-white LED lighting, which is the most energy-efficient, also appears to be the most ecologically unfriendly. Biologists, physicians and ecologists warn that blue-rich LED light disturbs the circadian day-and-night rhythm of living organisms, including humans, with potential negative health effects on individual species and whole ecosystems. Can the paradox be solved? This paper explores this question based on our transdisciplinary research project Light Pollution—A Global Discussion. It reveals how light pollution experts and lighting professionals see the challenges and potential of LED lighting from their different viewpoints. This expert feedback shows that “sustainable LED lighting” goes far beyond energy efficiency as it raises complex design issues that imply stakeholder negotiation. It also suggests that the LED paradox may be solved in context, but hardly in principle.},
  article-number   = {6160},
  comment          = {The LED paradox - the lowest energy blue-white LEDs are the worst for ecology

Questionnairre respondents with expertise in lighting, including lighting professionals, scientists, dark sky activists, hobby astronomers and conservationists, to gain an overview over debates on light as a form of pollution

Survey responses discover why LED contributes to more than light pollution:
- blue-rich colour temperature
- rebound effects
- increase in brightness
- bad design choices and installations
- glare
- poor luminaire design
- other - circadian disruption, eye pain

Also why LED lighting contributes less},
  creationdate     = {2026-06-01T13:59:56},
  journal          = {Sustainability},
  keywords         = {NightMapping,night,ALAN,ecology},
  modificationdate = {2026-06-01T14:09:36},
}

@Article{SchwendingerR2022,
  author           = {Schwendinger, Leni and Ross, Philip R.},
  date             = {2022-11},
  journaltitle     = {IOP Conference Series: Earth and Environmental Science},
  title            = {Envisioning Community Engagement in Smart Lighting Design},
  doi              = {10.1088/1755-1315/1099/1/012042},
  number           = {1},
  pages            = {012042},
  url              = {https://doi.org/10.1088/1755-1315/1099/1/012042},
  volume           = {1099},
  abstract         = {Smart Lighting is widely viewed as a means to reduce energy use, streamline city services and lower maintenance costs of public lighting. These are valid perspectives and useful pursuits, but they leave a blind spot that needs urgent attention: how the application of Smart Lighting technologies could affect and benefit people in public space. Illumination as it is currently deployed is mostly utilitarian. Creative and innovative opportunities are often overlooked. It is critical for designers to reclaim their role in this technological sea-change to combine the operational benefits of Smart Lighting with benefits for people on the ground. Involving the community should in our view be part of this process. Our goal is to unearth techniques and design approaches so that Smart Lighting becomes a flexible tool for community-informed night experiences.},
  comment          = {Most lighting is utilitarian, the public who experience it are rarely involved

This work focusses on community engagement ascertain who has a stake in the nighttime environment and who makes final decisions

Shades of Night study integrated observations and interviews from the night time:
- Quant data:
  - Gehl protocol to measure the circulation of people, bikes and motor vehicles, their behaviour
  - busines opening and closing times
  - lighting schedules
- Qual data:
  - intercept interviews
- Identified different experiences of night:
  - after-work activity
  - after-work recreation
  - night shift
  - after-hours recreation
  - early risers

Co-design and local participation to produce a pilot site design

Continuous evaluation

Light sketching - use of participants' photographs to allow discussion of qualities like glare, dynamics, adaptivity, colour temperature and light distribution

Also used theatre lighting approach to exlore joyful illumination of a location},
  creationdate     = {2026-06-01T14:16:14},
  journal          = {IOP Conference Series: Earth and Environmental Science},
  keywords         = {NightMapping,participatory,night,methodology},
  modificationdate = {2026-06-01T14:27:53},
  publisher        = {IOP Publishing},
}

